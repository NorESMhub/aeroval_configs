#!/bin/bash

# environment variables for the HYway project
# to make running containerized pyaerocom easy

# path to container file
if [ -z ${PYAEROCOM_SIF_PATH} ]
    then PYAEROCOM_SIF_PATH="/nird/datapeak/NS11106K/HYway/modelling_repository/pyaerocom/bin/pyaerocom.sif"
fi
# path to ~/MyPyaerocom
if [ -z ${PYAEROCOM_MYPYAEROCOM_PATH} ]
    then PYAEROCOM_MYPYAEROCOM_PATH="/nird/datapeak/NS11106K/HYway/modelling_repository/pyaerocom/MyPyaerocom.apptainer"
fi
# path to model data; base path with the model directories
if [ -z ${PYAEROCOM_DATA_PATH} ]
    then PYAEROCOM_DATA_PATH="/nird/datapeak/NS11106K/HYway/modelling_repository/pyaerocom/pyaerocom_data"
fi
# path where the aeroval data (the result of the analyses) will be stored
if [ -z ${PYAEROCOM_AEROVAL_DATA_PATH} ]
    then PYAEROCOM_AEROVAL_DATA_PATH="/nird/datapeak/NS11106K/HYway/modelling_repository/pyaerocom/aeroval_data"
fi
# base path to the aeroval config files
if [ -z ${PYAEROCOM_AEROVAL_CONFIG_PATH} ]
    then PYAEROCOM_AEROVAL_CONFIG_PATH="/nird/datapeak/NS11106K/HYway/modelling_repository/pyaerocom/aeroval_configs"
fi
# path where the log files will be stored
if [ -z ${PYAEROCOM_CONTAINER_LOG_PATH} ]
    then PYAEROCOM_CONTAINER_LOG_PATH="/nird/datapeak/NS11106K/HYway/modelling_repository/pyaerocom/aeroval_logs"
fi
# filename for the logfile AS SEEN FROM WITHIN THE CONTAINER
if [ -z ${PYAEROCOM_CONTAINER_LOG_FILE} ]
    then PYAEROCOM_CONTAINER_LOG_FILE="/nird/home/${USER}/container.data/aeroval_logs/aerocom.log"
fi
